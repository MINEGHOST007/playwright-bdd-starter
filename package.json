{
  "name": "playwright-bdd-starter",
  "version": "1.0.0",
  "description": "Starter template for BDD testing with Playwright using playwright-bdd",
  "scripts": {
    "test": "npx bddgen && npx playwright test",
    "test:generate": "npx bddgen",
    "test:ui": "npx bddgen && npx playwright test --ui",
    "test:headed": "npx bddgen && npx playwright test --headed",
    "test:debug": "npx bddgen && npx playwright test --debug",
    "test:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "playwright-bdd": "^8.4.1"
  },
  "keywords": [
    "playwright",
    "bdd",
    "cucumber",
    "gherkin",
    "testing",
    "e2e"
  ],
  "license": "MIT"
}
